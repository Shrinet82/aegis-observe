        },
        "clickhouse_sql": [
          {
            "disabled": false,
            "name": "A",
            "query": "SELECT ts.resource_attrs['k8s.namespace.name'] AS `k8s.namespace.name`, countIf(toInt32(s.last_value) = 1) AS Pending, countIf(toInt32(s.last_value) = 2) AS Running, countIf(toInt32(s.last_value) = 3) AS Succeeded, countIf(toInt32(s.last_value) = 4) AS Failed, countIf(toInt32(s.last_value) = 5) AS Unknown FROM (SELECT fingerprint, argMax(value, unix_milli) AS last_value FROM signoz_metrics.distributed_samples_v4 WHERE metric_name = 'k8s.pod.phase' AND unix_milli >= $end_timestamp_ms - 600000 AND unix_milli < $end_timestamp_ms GROUP BY fingerprint) AS s INNER JOIN (SELECT DISTINCT fingerprint, resource_attrs FROM signoz_metrics.distributed_time_series_v4_6hrs WHERE metric_name = 'k8s.pod.phase' AND temporality = 'Unspecified' AND resource_attrs['k8s.cluster.name'] = $k8s.cluster.name) AS ts USING fingerprint GROUP BY `k8s.namespace.name` ORDER BY Running DESC"
          }
        ],
        "id": "317b9c73-e36f-41de-96da-06bd9243c554",
