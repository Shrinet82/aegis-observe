# Aegis-Observe Environment Configuration Example
# Copy this file to .env and fill in environment-specific credentials.

# Azure OpenAI Credentials
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
AZURE_OPENAI_ENDPOINT="https://your-azure-resource.services.ai.azure.com/"

# Slack Credentials
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
SLACK_APP_TOKEN="xapp-your-slack-app-token"

# GitHub Credentials
GITHUB_TOKEN="your-github-personal-access-token"
GITHUB_REPO_URL="github.com/Shrinet82/flagship-gitops.git"

# SigNoz API & Telemetry Credentials (No Secrets Committed)
SIGNOZ_API_URL="http://localhost:8080"
SIGNOZ_API_KEY="your-signoz-api-key-here"
SIGNOZ_MCP_ENDPOINT="http://signoz-mcp.oppe2-app.svc.cluster.local:8000/mcp"
OTEL_EXPORTER_OTLP_ENDPOINT="http://signoz-ingester.signoz.svc.cluster.local:4317"
