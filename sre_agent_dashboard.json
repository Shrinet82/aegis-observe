{
  "title": "SRE Copilot Agent Metrics",
  "description": "Observability for the Autonomous SRE Agent",
  "tags": [
    "sre-copilot",
    "agent",
    "llm",
    "signoz"
  ],
  "version": "v5",
  "layout": [
    {
      "h": 6,
      "i": "panel-1",
      "w": 12,
      "x": 0,
      "y": 0,
      "moved": false,
      "static": false
    },
    {
      "h": 6,
      "i": "panel-2",
      "w": 12,
      "x": 12,
      "y": 0,
      "moved": false,
      "static": false
    },
    {
      "h": 8,
      "i": "panel-3",
      "w": 24,
      "x": 0,
      "y": 6,
      "moved": false,
      "static": false
    }
  ],
  "panelMap": {},
  "widgets": [
    {
      "id": "panel-1",
      "title": "LLM Token Usage (Prompt & Completion)",
      "description": "Real-time prompt and completion token consumption for GPT model reasoning spans.",
      "panelTypes": "graph",
      "opacity": "1",
      "nullZeroValues": "zero",
      "lineInterpolation": "spline",
      "lineStyle": "solid",
      "timePreferance": "GLOBAL_TIME",
      "legendPosition": "bottom",
      "query": {
        "queryType": "builder",
        "unit": "short",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "traces",
              "aggregateOperator": "sum",
              "aggregateAttribute": {
                "key": "gen_ai.usage.prompt_tokens",
                "dataType": "float64",
                "type": "tag",
                "isColumn": false
              },
              "filters": {
                "items": [
                  {
                    "key": {
                      "key": "serviceName",
                      "type": "tag"
                    },
                    "op": "=",
                    "value": "sre-copilot-agent"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [],
              "expression": "A",
              "disabled": false,
              "legend": "Prompt Tokens"
            },
            {
              "queryName": "B",
              "dataSource": "traces",
              "aggregateOperator": "sum",
              "aggregateAttribute": {
                "key": "gen_ai.usage.completion_tokens",
                "dataType": "float64",
                "type": "tag",
                "isColumn": false
              },
              "filters": {
                "items": [
                  {
                    "key": {
                      "key": "serviceName",
                      "type": "tag"
                    },
                    "op": "=",
                    "value": "sre-copilot-agent"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [],
              "expression": "B",
              "disabled": false,
              "legend": "Completion Tokens"
            }
          ],
          "queryFormulas": [],
          "queryTraceOperator": []
        }
      }
    },
    {
      "id": "panel-2",
      "title": "Agent Remediation Interventions",
      "titleCount": 0,
      "description": "Frequency of automated tool executions (scale_deployment, patch_pod_limits, trigger_retraining).",
      "panelTypes": "graph",
      "opacity": "1",
      "nullZeroValues": "zero",
      "lineInterpolation": "spline",
      "lineStyle": "solid",
      "timePreferance": "GLOBAL_TIME",
      "legendPosition": "bottom",
      "query": {
        "queryType": "builder",
        "unit": "short",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "traces",
              "aggregateOperator": "count",
              "aggregateAttribute": {
                "key": "",
                "dataType": "",
                "type": ""
              },
              "filters": {
                "items": [
                  {
                    "key": {
                      "key": "serviceName",
                      "type": "tag"
                    },
                    "op": "=",
                    "value": "sre-copilot-agent"
                  },
                  {
                    "key": {
                      "key": "name",
                      "type": "tag"
                    },
                    "op": "=",
                    "value": "execute_tool"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [
                {
                  "key": "tool.name",
                  "type": "tag"
                }
              ],
              "expression": "A",
              "disabled": false,
              "legend": "Tool: {{tool.name}}"
            }
          ],
          "queryFormulas": [],
          "queryTraceOperator": []
        }
      }
    },
    {
      "id": "panel-3",
      "title": "SRE Agent Decision Trace Audit",
      "description": "Live audit trail of SRE copilot diagnostic workflows, tool executions, and span durations.",
      "panelTypes": "table",
      "opacity": "1",
      "timePreferance": "GLOBAL_TIME",
      "query": {
        "queryType": "clickhouse_sql",
        "clickhouse_sql": [
          {
            "disabled": false,
            "legend": "Spans",
            "name": "A",
            "query": "SELECT timestamp, name AS span_name, duration_nano / 1000000 AS duration_ms, attributes_string['tool.name'] AS executed_tool, attributes_string['incident.context'] AS incident_context FROM signoz_traces.signoz_index_v3 WHERE serviceName = 'sre-copilot-agent' ORDER BY timestamp DESC LIMIT 50"
          }
        ]
      }
    }
  ]
}