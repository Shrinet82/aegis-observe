{
  "title": "SRE Copilot Agent Metrics",
  "description": "Observability for the Autonomous SRE Agent",
  "version": "v5",
  "layout": [
    {
      "h": 6,
      "i": "panel-1",
      "w": 12,
      "x": 0,
      "y": 0,
      "moved": false,
      "static": false
    },
    {
      "h": 6,
      "i": "panel-2",
      "w": 12,
      "x": 12,
      "y": 0,
      "moved": false,
      "static": false
    }
  ],
  "widgets": [
    {
      "id": "panel-1",
      "panelTypes": "graph",
      "title": "LLM Token Usage (Tokens)",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "traces",
              "aggregateOperator": "sum",
              "aggregateAttribute": {
                "key": "gen_ai.usage.prompt_tokens",
                "dataType": "float64",
                "type": "tag",
                "isColumn": false
              },
              "filters": {
                "items": [
                  {
                    "id": "1",
                    "key": {
                      "key": "serviceName",
                      "dataType": "string",
                      "type": "tag",
                      "isColumn": true
                    },
                    "op": "=",
                    "value": "sre-copilot-agent"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [],
              "expression": "A",
              "disabled": false,
              "legend": "Prompt Tokens"
            },
            {
              "queryName": "B",
              "dataSource": "traces",
              "aggregateOperator": "sum",
              "aggregateAttribute": {
                "key": "gen_ai.usage.completion_tokens",
                "dataType": "float64",
                "type": "tag",
                "isColumn": false
              },
              "filters": {
                "items": [
                  {
                    "id": "2",
                    "key": {
                      "key": "serviceName",
                      "dataType": "string",
                      "type": "tag",
                      "isColumn": true
                    },
                    "op": "=",
                    "value": "sre-copilot-agent"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [],
              "expression": "B",
              "disabled": false,
              "legend": "Completion Tokens"
            }
          ],
          "queryFormulas": []
        }
      }
    },
    {
      "id": "panel-2",
      "panelTypes": "graph",
      "title": "Agent Interventions",
      "query": {
        "queryType": "builder",
        "builder": {
          "queryData": [
            {
              "queryName": "A",
              "dataSource": "traces",
              "aggregateOperator": "count",
              "filters": {
                "items": [
                  {
                    "id": "1",
                    "key": {
                      "key": "serviceName",
                      "dataType": "string",
                      "type": "tag",
                      "isColumn": true
                    },
                    "op": "=",
                    "value": "sre-copilot-agent"
                  },
                  {
                    "id": "2",
                    "key": {
                      "key": "name",
                      "dataType": "string",
                      "type": "tag",
                      "isColumn": true
                    },
                    "op": "=",
                    "value": "execute_tool"
                  }
                ],
                "op": "AND"
              },
              "groupBy": [],
              "expression": "A",
              "disabled": false,
              "legend": "Actions Executed"
            }
          ],
          "queryFormulas": []
        }
      }
    }
  ]
}